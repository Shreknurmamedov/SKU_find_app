# Reference-image dataset manifests: generated by scripts/collect_reference_catalog.py.
# ~100 MB of CSV/JSONL whose image paths point at the local (gitignored) var/ cache,
# so they are reproducible build artifacts, not source. Keep them out of git.
data/catalog/reference_dataset*/
