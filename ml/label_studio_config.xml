<View>
  <Header value="Разметьте каждый видимый товар. Зеленый: наша продукция. Красный: конкурент или неизвестно."/>
  <Image name="image" value="$image" zoom="true" zoomControl="true" rotateControl="true"/>

  <PolygonLabels name="label" toName="image" strokeWidth="3" pointSize="small" opacity="0.35">
    <Label value="own_product" background="#24B667"/>
    <Label value="competitor_or_unknown" background="#E63A3A"/>
  </PolygonLabels>

  <RectangleLabels name="bbox" toName="image" opacity="0.25">
    <Label value="own_product" background="#24B667"/>
    <Label value="competitor_or_unknown" background="#E63A3A"/>
  </RectangleLabels>
</View>
